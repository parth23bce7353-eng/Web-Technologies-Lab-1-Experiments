<h1>Student Notes</h1>
<a href="/add">Add Note</a>
<% notes.forEach(note=>{ %>
<h3><%= note.title %></h3>
<p><%= note.subject %></p>
<p><%= note.description %></p>
<a href="/edit/<%= note._id %>">Edit</a>
<form action="/notes/<%= note._id %>?_method=DELETE" method="POST">
    <button>Delete</button>
</form>
<hr>
<% }) %>